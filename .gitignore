.env
.terraform

# Terraform working directory
.terraform/

# Terraform state files (VERY IMPORTANT - can contain secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output files
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc